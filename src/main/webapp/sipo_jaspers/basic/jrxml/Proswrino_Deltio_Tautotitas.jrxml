	<style name="defaultBold" fontName="Arial" isBold="true" pdfFontName="C:\Windows\Fonts\arialbd.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
	<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  B.BATH_SYN,
  O.OS_SYN,
  STR.STRA_EPWNYMO,
  STR.STRA_ONOMA,
  YPHR.YPHR_ESSO,
  STR.STRA_PATRWNYMO,
  STR.STRA_MHTRONYMO,
  STR.STRK_PROS_KWD,
  M.MONA_LEK,
  DATE_FORMAT(ATOM.ATOM_HMNIA_GENNHSHS, '%d/%m/%Y'),
  TOPO.TOPO_LEK,
  NOM.NOMO_LEK,
  ATOM.SXH_PROS,
  ATOM.XRWM_MAL,
  ATOM.XRWM_MAT,
  ATOM.ONOMA_SIZIGOY,
  SWM.SWMA_YPSOS,
  STAT.OIKO_KATA_LEK,
  TOPOSYPO.TOPO_LEK AS 'TOPOS SYPO'
FROM KEN_STRATEVMENOS STR
  LEFT JOIN KEN_YPHRESIAKA YPHR ON STR.STRK_PROS_KWD = YPHR.STRK_PROS_KWD
  LEFT JOIN KEN_ATOMIKA ATOM ON STR.STRK_PROS_KWD = ATOM.STRK_PROS_KWD
  LEFT JOIN KEN_SWMATOMETRIKA SWM ON STR.STRK_PROS_KWD = SWM.STRK_PROS_KWD
  LEFT JOIN KEN_OIKOGENEIAKA OIK ON STR.STRK_PROS_KWD = OIK.STRK_PROS_KWD
  LEFT JOIN OIKOGENEIAKH_KATASTASH STAT ON OIK.OIKO_KATA_KWD = STAT.OIKO_KATA_KWD
  LEFT JOIN TOPONYMIO TOPO ON ATOM.TOPO_DIAM_KWD = TOPO.TOPO_KWD
  LEFT JOIN NOMOS NOM ON TOPO.NOMO_KWD = NOM.NOMO_KWD
  LEFT JOIN BATHMOS B ON YPHR.BATH_KWD = B.BATH_KWD
  LEFT JOIN OS O ON YPHR.OS_KWD = O.OS_KWD
  LEFT JOIN MONADA M ON YPHR.YPHR_META_MONA_KWD = M.MONA_KWD
  LEFT JOIN TOPONYMIO TOPOSYPO ON M.MONA_TOPO_KWD = TOPOSYPO.TOPO_KWD
WHERE STR.STRK_PROS_KWD = $P{STRK_PROS_KWD}]]>
	</queryString>

		<queryString language="SQL">
			<![CDATA[SELECT  Y.STRK_PROS_KWD,Y.YEA_EPWNYMO,Y.YEA_ONOMA,Y.YEA_PATRWNYMO,Y.YEA_MATRIX_TEST,Y.YEA_LEK_TEST,Y.YEA_HLIKIA,Y.YEA_GRAM_GN,Y.YEA_KATAGWGH,Y.YEA_PARASTHMA,Y.YEA_PROSPATH,Y.YEA_EPITHIMIA
 FROM yea Y  INNER JOIN ken_yphresiaka K ON Y.STRK_PROS_KWD = K.STRK_PROS_KWD
 WHERE K.ENDEIXI_YEA IS TRUE AND K.PAROUSIASTIKE IS TRUE]]>

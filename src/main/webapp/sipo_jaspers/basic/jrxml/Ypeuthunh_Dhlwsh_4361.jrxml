	<columnHeader>
		<band height="570" splitType="Stretch">
			<staticText>
				<reportElement positionType="Float" x="6" y="17" width="553" height="14" uuid="ba1a94ec-8f7c-4069-968b-fd8951a1fc90"/>
				<textElement textAlignment="Center" verticalAlignment="Top">
					<font fontName="Arial" size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[(ΑΡΘΡΟ 4 ν. 4361/2016)]]></text>

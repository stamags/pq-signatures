					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[σύζυγο ή]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="354" width="524" height="15" uuid="c3671f80-a782-4fae-818a-b81026e83949"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[γονέα ή]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="369" width="524" height="15" uuid="d3a26f11-36ac-4a01-a581-c15a6417d9fa"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[αδελφό με αναπηρία σε ποσοστό 67% και άνω.]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="385" width="524" height="15" uuid="04c9f7a1-1882-457a-9cbd-3171d99b721d"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[(ε) Οπλίτης που επιμελείται με δικαστική απόφαση ή είναι ανάδοχος ή θετός γονέας ατόμου με αναπηρία 67% και άνω]]></text>
			</staticText>
			<staticText>

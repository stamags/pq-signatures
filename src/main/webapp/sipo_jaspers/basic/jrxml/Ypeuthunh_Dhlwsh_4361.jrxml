			<staticText>
				<reportElement positionType="Float" x="5" y="379" width="554" height="30" uuid="613e2ff1-add0-48db-af90-a47655397eb5"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[Σημείωση: Δηλώνονται υποχρεωτικά μέχρι τέσσερις Τόποι ή Μονάδες Επιθυμίας, αλλά τουλάχιστον δύο διαφορετικές φρουρές.]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="5" y="409" width="554" height="15" uuid="f29d9e90-0aa8-4870-b84b-9883e7bf94d1"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[15. ΕΙΔΙΚΕΣ ΚΑΤΗΓΟΡΙΕΣ ΤΟΠΟΘΕΤΗΣΕΩΝ]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="5" y="428" width="554" height="15" uuid="6907563c-591c-4194-ab6f-3fb119955d21"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[      Σε περίπτωση που επιλεγώ δηλώνω υπεύθυνα ότι:]]></text>
			</staticText>
			<frame>
				<reportElement positionType="Float" x="5" y="443" width="30" height="15" uuid="2dd6b0b8-2ec6-4db1-b157-653536fc7889"/>

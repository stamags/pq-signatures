			<staticText>
				<reportElement positionType="Float" x="5" y="228" width="554" height="15" uuid="3ed96057-203f-40c3-a9ba-95273798432f"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[γ. του Άρθρου 3 παράγραφος 2β του ν. 4361/2016 (Α 10) περίπτωση:]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="243" width="524" height="15" uuid="78197786-a6e9-4f22-b165-b79f73eaf19c"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[(α) Απώλεια συγγενούς α' βαθμού κατά το τελευταίο έτος πριν την κατάταξη ή κατά την διάρκεια της θητείας.]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="258" width="524" height="25" uuid="9f404bce-0dd8-4c12-90de-2f43ca024045"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[(β) Ανεργία γονέων με χαμηλό οικογενειακό εισόδημα, όπως κάθε φορά ορίζεται, εφόσον ο οπλίτης είναι
εξαρτώμενο μέλος.]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="283" width="524" height="25" uuid="d063c9c4-5af8-4db4-ba58-5c5414b1ac37"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[(γ) Ανεργία συζύγου για τον έγγαμο οπλίτη και συντρόφου για τον οπλίτη που έχει συνάψει σύμφωνο συμβίωσης,
με τουλάχιστον 1 τέκνο και χαμηλό οικογενειακό εισόδημα, όπως κάθε φορά ορίζεται.]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="308" width="524" height="15" uuid="2b24eef0-ce59-4b4d-928b-58b5880beeb1"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[(δ) Οπλίτης με ένα (1) τουλάχιστον]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="323" width="524" height="15" uuid="e5566ed5-9e43-4fef-8b88-a15b7003562a"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[τέκνο ή]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="37" y="339" width="524" height="15" uuid="03ad9ec1-904d-4133-8adc-90dcc0be05cc"/>

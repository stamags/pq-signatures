	<subDataset name="GLWSSES" uuid="6e797356-f01a-4f7e-9bc5-8193748e532c">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT  GLWS.GLWS_LEK, EPID.XENH_GLWS_EPID_LEK
FROM KEN_STRATEVMENOS STR
  LEFT JOIN KEN_XENES_GLWSSES LANG ON STR.STRK_PROS_KWD = LANG.STRK_PROS_KWD
  LEFT JOIN GLWSSA GLWS ON LANG.GLWS_KWD = GLWS.GLWS_KWD
  LEFT JOIN XENH_GLWSSA_EPIDOSH EPID ON LANG.EPIP_GLWS_KWD = EPID.XENH_GLWS_EPID_KWD
WHERE STR.STRK_PROS_KWD = $P{STRK_PROS_KWD}]]>
		</queryString>
		<field name="GLWS_LEK" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="GLWS_LEK"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="glwssa"/>
		</field>
		<field name="XENH_GLWS_EPID_LEK" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="XENH_GLWS_EPID_LEK"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="xenh_glwssa_epidosh"/>
		</field>
		<group name="GLWS_LEK">
			<groupExpression><![CDATA[$F{GLWS_LEK}]]></groupExpression>
		</group>
		<group name="XENH_GLWS_EPID_LEK">
			<groupExpression><![CDATA[$F{XENH_GLWS_EPID_LEK}]]></groupExpression>
		</group>
	</subDataset>
	<subDataset name="DIPLWMATA" uuid="dd8bfe75-ce04-4e7d-825a-cb3306452288">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT DIPLPOL.DIPL_POLI_LEK AS "DIPLWMA", DIPLALL.DIPL_POLI_KTHSH AS "HMNIA DIPLWMATOS"
FROM ken_stratevmenos STR
  left join ken_diplwmata_politika DIPLALL ON STR.STRK_PROS_KWD = DIPLALL.STRK_PROS_KWD
  left join diplwma_politiko DIPLPOL ON DIPLALL.DIPL_POLI_KDW = DIPLPOL.DIPL_POLI_KWD
WHERE STR.STRK_PROS_KWD = $P{STRK_PROS_KWD}]]>
		</queryString>
		<field name="DIPLWMA" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="DIPLWMA"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="diplwma_politiko"/>
		</field>
		<field name="HMNIA DIPLWMATOS" class="java.sql.Date">
			<property name="com.jaspersoft.studio.field.label" value="HMNIA DIPLWMATOS"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ken_diplwmata_politika"/>
		</field>
		<group name="DIPLWMA">
			<groupExpression><![CDATA[$F{DIPLWMA}]]></groupExpression>
		</group>
		<group name="HMNIA DIPLWMATOS">
			<groupExpression><![CDATA[$F{HMNIA DIPLWMATOS}]]></groupExpression>
		</group>
	</subDataset>
	<subDataset name="EPITHYMIES_TOPOTHETHSHS" uuid="e3623883-9c4f-4d06-92c2-0f8c42090b21">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT topo.EPIT_TOPO_AA, e.EPAR_LEK
  FROM ken_epithymies_topothethshs topo
INNER JOIN eparxia e on topo.EPAR_KWD = e.EPAR_KWD
WHERE topo.STRK_PROS_KWD = $P{STRK_PROS_KWD}
ORDER BY topo.EPIT_TOPO_AA ASC]]>
		</queryString>
		<field name="EPIT_TOPO_AA" class="java.lang.Integer">
			<property name="com.jaspersoft.studio.field.label" value="EPIT_TOPO_AA"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ken_epithymies_topothethshs"/>
		</field>
		<field name="EPAR_LEK" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="EPAR_LEK"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="eparxia"/>
		</field>
		<group name="EPAR_LEK">
			<groupExpression><![CDATA[$F{EPAR_LEK}]]></groupExpression>
		</group>
	</subDataset>
	<subDataset name="EPOPTHS STRATOLOGIAS" uuid="211a633e-75fe-48ad-927e-fcfd9bf4b07e">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<queryString language="SQL">
			<![CDATA[SELECT IPOG.ID AS "ID" , CONCAT(IPOG.EPWNYMO, " ", IPOG.ONOMA) AS "ONOM/MO IPOGRAFONTA", CONCAT(B.BATH_LEK, "(", O.OS_SYN, ")" ) AS "BATHMOS IPOGRAFONTA"
FROM ipografes IPOG
LEFT JOIN bathmos B on IPOG.BATH_KWD = B.BATH_KWD
LEFT JOIN os O on IPOG.OS_KWD = O.OS_KWD
WHERE IPOG.ID = 6]]>
		</queryString>
		<field name="ONOM/MO IPOGRAFONTA" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="ONOM/MO IPOGRAFONTA"/>
		</field>
		<field name="BATHMOS IPOGRAFONTA" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="BATHMOS IPOGRAFONTA"/>
		</field>
		<group name="ONOM/MO IPOGRAFONTA">
			<groupExpression><![CDATA[$F{ONOM/MO IPOGRAFONTA}]]></groupExpression>
		</group>
		<group name="BATHMOS IPOGRAFONTA">
			<groupExpression><![CDATA[$F{BATHMOS IPOGRAFONTA}]]></groupExpression>
		</group>
	</subDataset>
	<subDataset name="EPIPEDO MORFWSHS" uuid="cc5e61fe-419c-4923-b6e0-f9800fe023a1">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[select STR.STRK_PROS_KWD, EP.EPIP_MORF_LEK
FROM ken_stratevmenos STR
LEFT JOIN ken_morfwsh MOR on STR.STRK_PROS_KWD = MOR.STRK_PROS_KWD
LEFT JOIN epipedo_morfwshs EP ON MOR.EPIP_MORF_KWD = EP.EPIP_MORF_KWD
where STR.STRK_PROS_KWD = $P{STRK_PROS_KWD}]]>
		</queryString>
		<field name="STRK_PROS_KWD" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="STRK_PROS_KWD"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ken_stratevmenos"/>
		</field>
		<field name="EPIP_MORF_LEK" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="EPIP_MORF_LEK"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="epipedo_morfwshs"/>
		</field>
		<group name="EPIP_MORF_LEK">
			<groupExpression><![CDATA[$F{EPIP_MORF_LEK}]]></groupExpression>
		</group>
	</subDataset>
	<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
  STR.STRK_PROS_KWD,
  B.BATH_SYN,
  O.OS_SYN,
  date_format(YPHR.HMER_EGGRAFIS_SIPO, '%d/%m/%Y') as "hmnia katataxis",
  YPHR.YPHR_ESSO,
  STR.STRA_EPWNYMO,
  STR.STRA_ONOMA,
  STR.STRA_PATRWNYMO,
  STR.STRA_MHTRONYMO,
  M.MONA_LEK,
  EID.EIDI_LEK,
  date_format(ATOM.ATOM_HMNIA_GENNHSHS, '%d/%m/%Y'),
  KAT.KATA_EFED_LEK,
  E.EPAG_LEK,
  EPAG.EPAG_PROYPHRESIA,
  TOPO.TOPO_LEK,
  NOM.NOMO_LEK,
  ATOM.ATOM_DIEYTHYNSH,
  ATOM.ATOM_TAXKWD,
  DIPLPOL.DIPL_POLI_LEK                            AS "DIPLWMA",
  DIPLALL.DIPL_POLI_KTHSH                          AS "HMNIA DIPLWMATOS",
   EPITH.EPIT_PROEDR_FROURA_DKT,
   EPITH.EPIT_STRATONOMIA_DKT,
   EPITH.EPIT_DEA_DKT,
   EPITH.EPIT_ELDYK_DKT,
   EPITH.EPIT_KATADROMES_DKT,
   EPITH.EPIT_TEXN_DKT
FROM ken_stratevmenos STR
  left join ken_atomika ATOM ON STR.STRK_PROS_KWD = ATOM.STRK_PROS_KWD
  left join ken_yphresiaka YPHR ON STR.STRK_PROS_KWD = YPHR.STRK_PROS_KWD
  left join ken_oikogeneiaka OIK ON STR.STRK_PROS_KWD = OIK.STRK_PROS_KWD
  left join ken_diplwmata_politika DIPLALL ON STR.STRK_PROS_KWD = DIPLALL.STRK_PROS_KWD
    left join ken_epithymia EPITH ON STR.STRK_PROS_KWD = EPITH.STRK_PROS_KWD
  left join diplwma_politiko DIPLPOL ON DIPLALL.DIPL_POLI_KDW = DIPLPOL.DIPL_POLI_KWD
  left join toponymio TOPO ON ATOM.TOPO_DIAM_KWD = TOPO.TOPO_KWD
  left join nomos NOM ON TOPO.NOMO_KWD = NOM.NOMO_KWD
  left join ken_epaggelmata EPAG ON STR.STRK_PROS_KWD = EPAG.STRK_PROS_KWD
  left join epaggelma E ON EPAG.EPAG_KWD = E.EPAG_KWD
  left join bathmos B ON YPHR.BATH_KWD = B.BATH_KWD
  left join os O ON YPHR.OS_KWD = O.OS_KWD
  left join eidikothta EID ON YPHR.YPHR_EIDI_KWD = EID.EIDI_KWD
  left join katastash_efedrou KAT ON STR.KATA_EFED_KWD = KAT.KATA_EFED_KWD
  left join monada M ON YPHR.YPHR_META_MONA_KWD = M.MONA_KWD
WHERE STR.STRK_PROS_KWD = $P{STRK_PROS_KWD}]]>
	</queryString>

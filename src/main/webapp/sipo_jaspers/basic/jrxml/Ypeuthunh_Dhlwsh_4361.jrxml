			</textField>
			<staticText>
				<reportElement positionType="Float" x="4" y="518" width="554" height="15" uuid="8aa64cbd-2bc8-4a4f-9b43-7cd3fb2246ba"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[16. Δηλώνω ότι ανήκω στην -ις παρακάτω κατηγορία -ες.]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="4" y="533" width="554" height="15" uuid="aff17da0-ba1c-4206-9591-93b3116190ad"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[α. του Άρθρου 75 ν. 3421/2005 (Α 302)]]></text>
			</staticText>
			<frame>
				<reportElement positionType="Float" x="4" y="548" width="30" height="15" uuid="473cc6d7-c356-4dca-8c2f-11f18132c6a5"/>
				<box>
					<pen lineWidth="0.5"/>
				</box>
			</frame>
			<staticText>
				<reportElement positionType="Float" x="34" y="548" width="524" height="15" uuid="84f4f1fd-3b8e-448c-a530-9dfdaee429fc"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[Παρ. 3: Οπλίτης που έχει γονέα με βαριά κινητική αναπηρία τουλάχιστον σε ποσοστό 67% και άνω ή είναι τυφλός]]></text>
			</staticText>
		</band>
	</columnHeader>
	<summary>
		<band height="724">
			<frame>
				<reportElement positionType="Float" x="4" y="3" width="30" height="25" uuid="f033679d-f076-4a2b-adb6-efdf9313c80f"/>
				<box>
					<pen lineWidth="0.5"/>
				</box>
			</frame>
			<staticText>
				<reportElement positionType="Float" x="34" y="3" width="524" height="25" uuid="9fa749ef-2e25-45ad-ab89-4dea848c8497"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[Παρ. 4α: Ύπαρξη αδελφού που εκπληρώνει ταυτόχρονα την στρατιωτική υποχρέωση στις τάξεις των ενόπλων δυνάμεων.]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="15" y="74" width="544" height="15" uuid="8c63dc33-8bb8-4b65-9563-acfd2fe4fe91"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="true" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[παράγραφος 2]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="93" width="524" height="15" uuid="f3da04e1-9187-4b52-b9d0-c87dbb6f5132"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[(α) Οπλίτης που είναι δικαιούχος του προγράμματος "Στέγαση και Επανένταξη"]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="108" width="524" height="15" uuid="de8d07ad-7ffc-4150-89e9-744a98ed253b"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[(β) Οπλίτης που είναι εξαρτώμενο μέλος δικαιούχου του προγράμματος "Στέγαση και Επανένταξη"]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="123" width="524" height="25" uuid="2b816558-1c90-4375-93e6-91226985d1dd"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[(γ) Οπλίτης με τουλάχιστον ένα (1) τέκνο που διαβιώνει σε συνθήκες ακραίας φτώχειας και λαμβάνει τουλάχιστον
μία από τις παροχές, που προβλέπονται στο ν. 4320/2015 (Α 29).]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="148" width="524" height="25" uuid="426fb417-9f2b-473f-b10f-e1df39dd5460"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[(δ) Οπλίτης που είναι εξαρτώμενο μέλος δικαιούχου μιας από από τις παροχές, που προβλέπονται στο ν.
4320/2015 (Α 29) και διαβιώνει σε συνθήκες ακραίας φτώχειας.]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="173" width="524" height="15" uuid="3b6cc396-27b3-49e5-aade-3df36e49ed99"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[(ε) Οπλίτης με τουλάχιστον ένα (1) τέκνο ΑΜΕΑ]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="15" y="188" width="544" height="15" uuid="19db1671-8d86-4d11-b617-a275f8f98346"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="true" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[παράγραφος 3
]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="5" y="57" width="554" height="15" uuid="c4877c1e-d6a5-4033-a683-dd36f153959e"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[β. του Άρθρου 6 ν.4361/2016 (Α 10)]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="203" width="524" height="25" uuid="9e443076-4cf4-4c22-8a2e-6b3468a6d213"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[Οπλίτης που έχει ολοκληρώσει επιτυχώς πρόγραμμα θεραπείας εξαρτημένων ατόμων από ναρκωτικές ουσίες
στους εγκεκριμένους οργανισμούς ή φορείς του άρθρου 51 του ν. 4139/2013 (Α 74)]]></text>
			</staticText>
			<frame>
				<reportElement positionType="Float" x="5" y="93" width="30" height="14" uuid="804357dd-2c83-4537-b66f-07192566f2ac"/>
				<box>
					<pen lineWidth="0.5"/>
				</box>
			</frame>
			<frame>
				<reportElement positionType="Float" x="5" y="108" width="30" height="14" uuid="712aaaa1-3fd0-4ca8-a1c1-ce57fbb38062"/>
				<box>
					<pen lineWidth="0.5"/>
				</box>
			</frame>
			<frame>
				<reportElement positionType="Float" x="5" y="123" width="30" height="25" uuid="d5848434-535c-4d92-a0e6-282a970bb4e9"/>
				<box>
					<pen lineWidth="0.5"/>
				</box>
			</frame>
			<frame>
				<reportElement positionType="Float" x="5" y="148" width="30" height="25" uuid="8cffa4ba-9b71-487f-a767-acf9af91d486"/>
				<box>
					<pen lineWidth="0.5"/>
				</box>
			</frame>
			<frame>
				<reportElement positionType="Float" x="5" y="173" width="30" height="15" uuid="e583386a-2701-4e3e-8a57-01d3125b8e90"/>
				<box>
					<pen lineWidth="0.5"/>
				</box>
			</frame>
			<frame>
				<reportElement positionType="Float" x="5" y="203" width="30" height="25" uuid="acf5efcb-7940-42f0-b047-a15ed3ea0ba1"/>
				<box>
					<pen lineWidth="0.5"/>
				</box>
			</frame>
			<frame>
				<reportElement x="5" y="29" width="30" height="25" uuid="7ca85f6c-818e-4162-8b19-d2e7011dad83"/>
				<box>
					<pen lineWidth="0.5"/>
				</box>
			</frame>
			<staticText>
				<reportElement positionType="Float" x="35" y="28" width="524" height="25" uuid="dcd562c5-6344-4b92-891b-376ffac72c01"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[Παρ. 4β: Ύπαρξη δίδυμου αδελφού που εκπληρώνει ταυτόχρονα τη στρατιωτική του υποχρέωση στις τάξεις των ενόπλων δυνάμεων.]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="440" width="524" height="25" uuid="3aea4755-6e9f-427e-9e5f-302710cb64a7"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[(η) Οπλίτης ορφανός και από τους δύο γονείς χωρίς εξαρτώμενα μέλη, ολοκλήρου θητείας και οι αδελφοί του είναι εξαρτώμενα μέλη.]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="465" width="524" height="15" uuid="ceefa57e-bbdc-481e-9e56-51a118c0c50c"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[(θ) Οπλίτης, μέλος πολύτεκνης, τρίτεκνης ή μονογονεϊκής οικογένειεας .]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="480" width="524" height="15" uuid="9db627d9-2cba-4355-bc56-10ab183eab8e"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[(ι) Ανεργία γονέα και χαμηλό οικογενειακό εισόδημα, εφόσον ο οπλίτης είναι εξαρτώμενο μέλος.]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="495" width="524" height="15" uuid="8a649ffa-4562-4a3b-ab33-380f1b81bade"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[(ια) Ανεργία συζύγου για τον έγγαμο ή σύντροφου για συμφωνο συμβίωσης και χαμηλό οικογενειακό εισόδημα]]></text>
			</staticText>
			<staticText>
				<reportElement positionType="Float" x="35" y="510" width="524" height="25" uuid="6ffde67d-7153-4277-a6b9-2990e9d257b2"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Arial" size="10" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[Λοιπά σοβαρά οικογενειακά-κοινωνικά-οικονομικά προβλήματα οπλίτη ή μέλους αυτού τα οποία δεν περιλαμβάνονται στις ανωτέρω κατηγορίες:]]></text>
			</staticText>
			<frame>
				<reportElement positionType="Float" x="5" y="440" width="30" height="25" uuid="3ab90501-a05c-40b2-b108-bff572aca6da"/>
				<box>
					<pen lineWidth="0.5"/>
				</box>
			</frame>
			<frame>
				<reportElement positionType="Float" x="5" y="465" width="30" height="15" uuid="139adf10-4ebb-4730-878d-c8406d5a17f7"/>
				<box>
					<pen lineWidth="0.5"/>
				</box>
			</frame>
			<frame>
				<reportElement positionType="Float" x="5" y="480" width="30" height="15" uuid="8da3af64-cec0-42fa-8f0e-122ec24fac20"/>
				<box>
					<pen lineWidth="0.5"/>
				</box>
			</frame>
			<frame>
				<reportElement positionType="Float" x="5" y="495" width="30" height="15" uuid="6ebd3795-fc95-4878-9ce9-b77f9d1f13bb"/>
				<box>
					<pen lineWidth="0.5"/>
				</box>
			</frame>
			<frame>

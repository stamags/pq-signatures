	<subDataset name="YDKTHS" uuid="5e5b766c-cbae-4898-a508-109c0fe4dd92">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<queryString language="SQL">
			<![CDATA[SELECT IPOG.ID AS "ID" , CONCAT(IPOG.EPWNYMO, " ", IPOG.ONOMA) AS "ONOM/MO IPOGRAFONTA", CONCAT(B.BATH_LEK, "(", O.OS_SYN, ")" ) AS "BATHMOS IPOGRAFONTA"
FROM ipografes IPOG
LEFT JOIN bathmos B on IPOG.BATH_KWD = B.BATH_KWD
LEFT JOIN os O on IPOG.OS_KWD = O.OS_KWD
WHERE IPOG.ID = 4]]>
		</queryString>
		<field name="ID" class="java.lang.Integer">
			<property name="com.jaspersoft.studio.field.label" value="ID"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ipografes"/>
		</field>
		<field name="ONOM/MO IPOGRAFONTA" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="ONOM/MO IPOGRAFONTA"/>
		</field>
		<field name="BATHMOS IPOGRAFONTA" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="BATHMOS IPOGRAFONTA"/>
		</field>
		<group name="ONOM/MO IPOGRAFONTA">
			<groupExpression><![CDATA[$F{ONOM/MO IPOGRAFONTA}]]></groupExpression>
		</group>
		<group name="BATHMOS IPOGRAFONTA">
			<groupExpression><![CDATA[$F{BATHMOS IPOGRAFONTA}]]></groupExpression>
		</group>
	</subDataset>
	<subDataset name="OMADIKO FYLLO POREIAS" uuid="85524929-279b-4a90-b873-2db6d9fafc89">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT B.BATH_LEK,O.OS_SYN,STR.STRA_EPWNYMO,STR.STRA_ONOMA,STR.STRA_PATRWNYMO,STR.STRK_PROS_KWD
FROM ken_stratevmenos STR 
LEFT OUTER JOIN ken_yphresiaka K ON STR.STRK_PROS_KWD = K.STRK_PROS_KWD
LEFT OUTER JOIN bathmos B ON K.BATH_KWD = B.BATH_KWD
LEFT OUTER JOIN os O ON K.OS_KWD = O.OS_KWD
WHERE K.STRK_PROS_KWD in ($P!{STRK_PROS_KWD})]]>
		</queryString>
		<field name="BATH_LEK" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="BATH_LEK"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="bathmos"/>
		</field>
		<field name="OS_SYN" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="OS_SYN"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="os"/>
		</field>
		<field name="STRA_EPWNYMO" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="STRA_EPWNYMO"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ken_stratevmenos"/>
		</field>
		<field name="STRA_ONOMA" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="STRA_ONOMA"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ken_stratevmenos"/>
		</field>
		<field name="STRA_PATRWNYMO" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="STRA_PATRWNYMO"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ken_stratevmenos"/>
		</field>
		<field name="STRK_PROS_KWD" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="STRK_PROS_KWD"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ken_stratevmenos"/>

	<subDataset name="ATOMIKAEGGRAFA" uuid="040a1c52-a828-4301-9030-e3b26a05d2b8">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="278"/>
		<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="716"/>
		<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT STR.STRA_ONOMA,STR.STRA_EPWNYMO,STR.STRK_PROS_KWD,M.MONA_LEK,T.TOPO_LEK,MO.MONA_LEK as MONADAMETATHESIS
FROM ken_stratevmenos STR INNER JOIN ken_yphresiaka K ON STR.STRK_PROS_KWD = K.STRK_PROS_KWD
INNER JOIN monada M ON M.MONA_KWD = K.YPHR_META_MONA_KWD
INNER JOIN toponymio T ON T.TOPO_KWD=M.MONA_TOPO_KWD
INNER JOIN monada MO on MO.MONA_KWD = K.MONADA_METATHESIS
WHERE STR.STRK_PROS_KWD in ($P!{STRK_PROS_KWD})]]>
		</queryString>
		<field name="STRA_ONOMA" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="STRA_ONOMA"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ken_stratevmenos"/>
		</field>
		<field name="STRA_EPWNYMO" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="STRA_EPWNYMO"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ken_stratevmenos"/>
		</field>
		<field name="STRK_PROS_KWD" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="STRK_PROS_KWD"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ken_stratevmenos"/>
		</field>
		<field name="MONA_LEK" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="MONA_LEK"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="monada"/>
		</field>
		<field name="TOPO_LEK" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="TOPO_LEK"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="toponymio"/>
		</field>
		<field name="MONADAMETATHESIS" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="MONADAMETATHESIS"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="monada"/>
		</field>
	</subDataset>
	<subDataset name="AXKOS_STRATOLOGIAS" uuid="dc34fbc9-6de0-454d-8d2a-ebe0e7447660">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<queryString language="SQL">
			<![CDATA[SELECT IPOG.ID AS "ID" , CONCAT(IPOG.EPWNYMO, " ", IPOG.ONOMA) AS "ONOM/MO IPOGRAFONTA", CONCAT(B.BATH_LEK, "(", O.OS_SYN, ")" ) AS "BATHMOS IPOGRAFONTA"
FROM kends.ipografes IPOG
LEFT JOIN kends.bathmos B on IPOG.BATH_KWD = B.BATH_KWD
LEFT JOIN kends.os O on IPOG.OS_KWD = O.OS_KWD
WHERE IPOG.ID = 7]]>
		</queryString>
		<field name="ONOM/MO IPOGRAFONTA" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="ONOM/MO IPOGRAFONTA"/>
		</field>
		<field name="BATHMOS IPOGRAFONTA" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="BATHMOS IPOGRAFONTA"/>
		</field>
		<group name="ONOM/MO IPOGRAFONTA">
			<groupExpression><![CDATA[$F{ONOM/MO IPOGRAFONTA}]]></groupExpression>
		</group>
		<group name="BATHMOS IPOGRAFONTA">
			<groupExpression><![CDATA[$F{BATHMOS IPOGRAFONTA}]]></groupExpression>
		</group>
	</subDataset>
	<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT STR.STRA_ONOMA,STR.STRA_EPWNYMO,STR.STRK_PROS_KWD,M.MONA_LEK,T.TOPO_LEK,MO.MONA_LEK as MONADAMETATHESIS
FROM ken_stratevmenos STR
INNER JOIN ken_yphresiaka K ON STR.STRK_PROS_KWD = K.STRK_PROS_KWD
INNER JOIN monada M ON M.MONA_KWD = K.YPHR_META_MONA_KWD
INNER JOIN toponymio T ON T.TOPO_KWD=M.MONA_TOPO_KWD
INNER JOIN monada MO on MO.MONA_KWD = K.MONADA_METATHESIS
WHERE STR.STRK_PROS_KWD in ($P!{STRK_PROS_KWD})]]>
	</queryString>

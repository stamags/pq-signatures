	<subDataset name="ALLAGES_SI" uuid="0bb025b1-e14c-474e-bd8f-ef3ef24adbff">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT @rownum := @rownum + 1 AS aa,
       DATE_FORMAT(SI.IKAN_HMNIA, '%d/%m/%Y'),
       STR.STRK_PROS_KWD,
       IKAN.IKAN_EFED_SYN   AS "IKANOTHTA",
       SI.IKAN_GNWMATEYSH,
       PD.PD_PARAG_LEK      AS "PASXWN",
       PD.PD_ARTHRO         AS "ARTHRO",
       PD.PROEDR_DIATAGMA   AS "PD",
       SI.IKAN_AR_GNWMAT    AS "ARITHM APOFASIS",
       EA.EPIT_APALL_LEK    AS "EPITROPH APALAG"
FROM ken_stratevmenos STR
         left join ken_ikanothtes SI ON STR.STRK_PROS_KWD = SI.STRK_PROS_KWD
         left join ikanothta_efedrou IKAN ON SI.IKAN_EFED_KWD = IKAN.IKAN_EFED_KWD
         left join PD_133_02 PD ON SI.IKAN_PD_PARAG = PD.PD_PARAG_KWD
         left join EPITROPH_APALLAGWN EA ON SI.IKAN_EPITROPH_APALL = EA.EPIT_APALL_KWD
WHERE STR.STRK_PROS_KWD = $P{STRK_PROS_KWD}
ORDER BY SI.IKAN_HMNIA ASC]]>
		</queryString>
		<field name="aa" class="java.lang.Double">
			<property name="com.jaspersoft.studio.field.label" value="aa"/>
		</field>
		<field name="DATE_FORMAT(SI.IKAN_HMNIA, &apos;%d/%m/%Y&apos;)" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="DATE_FORMAT(SI.IKAN_HMNIA, &apos;%d/%m/%Y&apos;)"/>
		</field>
		<field name="STRK_PROS_KWD" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="STRK_PROS_KWD"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ken_stratevmenos"/>
		</field>
		<field name="IKANOTHTA" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="IKANOTHTA"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ikanothta_efedrou"/>
		</field>
		<field name="IKAN_GNWMATEYSH" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="IKAN_GNWMATEYSH"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ken_ikanothtes"/>
		</field>
		<field name="PASXWN" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="PASXWN"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="pd_133_02"/>
		</field>
		<field name="ARTHRO" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="ARTHRO"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="pd_133_02"/>
		</field>

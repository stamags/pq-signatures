			<property name="com.jaspersoft.studio.field.label" value="ARITHM APOFASIS"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ken_ikanothtes"/>
		</field>
		<field name="EPITROPH APALAG" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="EPITROPH APALAG"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="epitroph_apallagwn"/>
		</field>
		<group name="aa">
			<groupExpression><![CDATA[$F{aa}]]></groupExpression>
		</group>
		<group name="DATE_FORMAT(SI.IKAN_HMNIA, &apos;%d/%m/%Y&apos;)">

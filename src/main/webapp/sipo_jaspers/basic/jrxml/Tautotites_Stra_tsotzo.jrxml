	<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT ST.STRK_PROS_KWD,
       KAT.KATA_EFED_LEK,
       YP.YPHR_ESSO,
       BATH.BATH_OLOGRAFOS,
       OS.OS_SYN,
       ST.STRA_EPWNYMO,
       ST.STRA_ONOMA,
       ST.STRA_PATRWNYMO,
       ST.STRA_MHTRONYMO,
       ST.STRA_SURNAME,
       ATOM.XRWM_MAL,
       ATOM.XRWM_MAT,
       ATOM.SXH_PROS,
       ST.STRA_NAME,
       SWM.SWMA_YPSOS,
       ST.STRA_FATH_NAME,
       DATE_FORMAT(ATOM.ATOM_HMNIA_GENNHSHS, '%d/%m/%Y'),
       TOPGEN.TOPO_LEK,
       TOPDHM.TOPO_LEK,
       AIM.OMADA_SYNT_EN,
       AIM.RESHUS_EN,
       AIM.OMADA_SYNT_GR,
       AIM.RESHUS_GR,
       BATH.BATH_OLOGRAFOS_EN,
       ATOM.COLOUR_EYES,
       ATOM.COLOUR_HAIR,
       DIA.ONOMA_SXHM,
       ATOM.AR_TAUTOTHTAS,
       BATH.BATH_LEK,
       IPO.EPWNYMO,
       IPO.ONOMA,
       IPO.KATHIKON,
       ATOM.TAYTOTHTA_POLH_GENN,
       ATOM.TAUTOTHTA_POLH_DIAMONHS,
       BATHMOS.BATH_LEK AS BATHMOS_IPOGRAFWNTA,
       OSIPO.OS_SYN AS OPLO_IPOGRAFONTA,
         ATOM.ONOMA_SIZIGOY
FROM diaxeirsi_ipografwn DIA,
     ken_stratevmenos ST,
     ken_yphresiaka YP,
     os OS,
     os OSIPO,
     bathmos BATH,
     bathmos BATHMOS,
     katastash_efedrou KAT,
     ken_atomika ATOM,
     ken_swmatometrika SWM,
     toponymio TOPGEN,
     toponymio TOPDHM,
     ken_iatrika IAT,
     aima AIM,
     ipografes IPO
WHERE ST.STRK_PROS_KWD = YP.STRK_PROS_KWD
  AND ST.OS_KWD = OS.OS_KWD
  AND YP.BATH_KWD = BATH.BATH_KWD
  AND ST.KATA_EFED_KWD = KAT.KATA_EFED_KWD
  AND ST.STRK_PROS_KWD = ATOM.STRK_PROS_KWD
  AND ST.STRK_PROS_KWD = SWM.STRK_PROS_KWD
  AND ATOM.TOPO_GENH_KWD = TOPGEN.TOPO_KWD
  AND ATOM.TOPO_DIAM_KWD = TOPDHM.TOPO_KWD
  AND ST.STRK_PROS_KWD = IAT.STRK_PROS_KWD
  AND IAT.AIMA_KWD = AIM.AIMA_KWD
  AND IPO.BATH_KWD = BATHMOS.BATH_KWD
  AND IPO.OS_KWD = OSIPO.OS_KWD
  AND IPO.ID = 8
  AND ST.STRK_PROS_KWD IN  ($P!{STRK_PROS_KWD})]]>
	</queryString>

	<detail>
		<band height="523" splitType="Stretch">
			<staticText>
				<reportElement style="defaultBold" x="202" y="0" width="150" height="30" uuid="2a9152e3-9432-46de-bf69-7b3c90235745"/>
				<textElement textAlignment="Center">
					<font fontName="Arial" size="15" isBold="true" isUnderline="true"/>
				</textElement>
				<text><![CDATA[ΦΥΛΛΟ ΠΟΡΕΙΑΣ]]></text>
			</staticText>
			<textField>
				<reportElement positionType="Float" x="10" y="60" width="540" height="180" uuid="fda01319-eec3-48cc-b99a-89412e7ec4b2"/>
				<textElement textAlignment="Justified">
					<font fontName="Arial" size="12" isBold="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
					<paragraph lineSpacing="Double"/>
				</textElement>
				<textFieldExpression><![CDATA["Για τον  "+$F{BATH_SYN} +" "+ " ( " + $F{OS_SYN}+ " ) " +" " + $F{STRA_EPWNYMO} + " " + $F{STRA_ONOMA} + " του " + $F{STRA_PATRWNYMO} + "  (Σ.Α.: " + $F{STRK_PROS_KWD}+"  ) " +  " , απερχόμενο στο/ην " + $F{MONA_LEK} + " "+ $F{TOPO_LEK} + " " + $F{NOMO_LEK} + " με ειδικότητα "  + $F{EIDI_LEK} + "  σε εκτέλεση της υπ'αριθμ.: " + ($F{F_DIATAGIS} == null ? " - " : $F{F_DIATAGIS}) + " λόγω μεταθέσεως."]]></textFieldExpression>
			</textField>

	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="KENDS LOCALHOST"/>
	<style name="defaultBold" fontName="Arial" isBold="true" pdfFontName="C:\Windows\Fonts\arialbd.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
	<subDataset name="YDKTHS" uuid="5e5b766c-cbae-4898-a508-109c0fe4dd92">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<queryString language="SQL">
			<![CDATA[SELECT IPOG.ID AS "ID" , CONCAT(IPOG.EPWNYMO, " ", IPOG.ONOMA) AS "ONOM/MO IPOGRAFONTA", CONCAT(B.BATH_LEK, "(", O.OS_SYN, ")" ) AS "BATHMOS IPOGRAFONTA"
FROM ipografes IPOG
LEFT JOIN bathmos B on IPOG.BATH_KWD = B.BATH_KWD
LEFT JOIN os O on IPOG.OS_KWD = O.OS_KWD
WHERE IPOG.ID = 4]]>
		</queryString>
		<field name="ID" class="java.lang.Integer">
			<property name="com.jaspersoft.studio.field.label" value="ID"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ipografes"/>
		</field>
		<field name="ONOM/MO IPOGRAFONTA" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="ONOM/MO IPOGRAFONTA"/>
		</field>
		<field name="BATHMOS IPOGRAFONTA" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="BATHMOS IPOGRAFONTA"/>
		</field>
		<group name="ONOM/MO IPOGRAFONTA">
			<groupExpression><![CDATA[$F{ONOM/MO IPOGRAFONTA}]]></groupExpression>
		</group>
		<group name="BATHMOS IPOGRAFONTA">
			<groupExpression><![CDATA[$F{BATHMOS IPOGRAFONTA}]]></groupExpression>
		</group>
	</subDataset>
	<subDataset name="DIATAGIMETATHESIS" uuid="9c723f86-8d84-496e-b7e9-09fccdf680fb">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<queryString language="SQL">
			<![CDATA[SELECT F_DIATAGIS FROM diaxeirsi_ipografwn]]>
		</queryString>
		<field name="F_DIATAGIS" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="F_DIATAGIS"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="diaxeirsi_ipografwn"/>
		</field>
	</subDataset>
	<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT STR.`STRK_PROS_KWD`,FD.F_DIATAGIS, DATE_FORMAT(YP.YPHR_META_MONA_HMNIA, '%d/%m/%Y')  AS YPHR_HMNIA_MONADA, B.BATH_SYN, O.OS_SYN, E.EIDI_LEK, STR.STRA_EPWNYMO, STR.STRA_ONOMA, STR.STRA_PATRWNYMO, M.MONA_LEK, TOPMET.TOPO_LEK, NOM.NOMO_LEK, MON.MONA_LEK AS 'SYPO', TOPO.`TOPO_LEK` AS 'TOPOS SYPO', NOMSYP.`NOMO_LEK` AS 'NOMOS SYPO', DATE_FORMAT(YP.HMER_PAROUS_NEA_MON, '%d/%m/%Y') AS 'HMNIA PAROUSIASEWS', DATE_FORMAT(YP.HMER_DIAGRAFIS_SIPO, '%d/%m/%Y') AS 'HMNIA DIAGRAFIS', DATE_FORMAT(YP.HMER_XOR_FIL_POR, '%d/%m/%Y') AS 'HMNIA ANAXWRISEWS'
FROM `ken_stratevmenos` STR
LEFT JOIN `ken_yphresiaka` YP ON STR.`STRK_PROS_KWD` = YP.`STRK_PROS_KWD`
LEFT JOIN `bathmos` B ON YP.`BATH_KWD` = B.`BATH_KWD`
LEFT JOIN `os` O ON YP.`OS_KWD` = O.`OS_KWD`
LEFT JOIN `eidikothta` E ON YP.`YPHR_EIDI_KWD` = E.`EIDI_KWD`
LEFT JOIN `monada` M ON YP.`MONADA_METATHESIS` = M.`MONA_KWD`
LEFT JOIN `monada` MON ON YP.`YPHR_META_MONA_KWD` = MON.`MONA_KWD`
LEFT JOIN `toponymio` TOPO ON MON.`MONA_TOPO_KWD` = TOPO.`TOPO_KWD`
LEFT JOIN `toponymio` TOPMET ON M.`MONA_TOPO_KWD` = TOPMET.`TOPO_KWD`
LEFT JOIN `nomos` NOM ON TOPMET.`NOMO_KWD` = NOM.`NOMO_KWD`
LEFT JOIN `nomos` NOMSYP ON TOPO.`NOMO_KWD` = NOMSYP.`NOMO_KWD`,`diaxeirsi_ipografwn`  FD
WHERE STR.STRK_PROS_KWD = $P{STRK_PROS_KWD}]]>
	</queryString>

$F{YPHR_ESSO} % 10 == 4 ? "Δ'" : $F{YPHR_ESSO} % 10 == 5 ? "Ε'" : $F{YPHR_ESSO} % 10 == 6 ? "ΣΤ'" : "-"]]></textFieldExpression>

	<subDataset name="DIATAGI_METATHESIS" uuid="56e88ef7-a3df-4c93-898f-1c9048bb7114">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="KENDS"/>
		<queryString language="SQL">
			<![CDATA[SELECT F_DIATAGIS FROM diatagi_metathesis]]>
		</queryString>
		<field name="F_DIATAGIS" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="F_DIATAGIS"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="diatagi_metathesis"/>
		</field>
	</subDataset>
	<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT STR.`STRK_PROS_KWD`, M.MONA_LEK, MON.MONA_LEK AS 'SYPO', NOMSYP.`NOMO_LEK` AS 'NOMOS SYPO',  TOPO.`TOPO_LEK` AS 'TOPOS SYPO'
FROM kends.`ken_stratevmenos` STR
  LEFT JOIN kends.`ken_yphresiaka` YP ON STR.`STRK_PROS_KWD` = YP.`STRK_PROS_KWD`
  LEFT JOIN kends.`bathmos` B ON YP.`BATH_KWD` = B.`BATH_KWD`
  LEFT JOIN kends.`os` O ON YP.`OS_KWD` = O.`OS_KWD`
  LEFT JOIN kends.`monada` M ON YP.`MONADA_METATHESIS` = M.`MONA_KWD`
  LEFT JOIN kends.`monada` MON ON YP.`YPHR_META_MONA_KWD` = MON.`MONA_KWD`
  LEFT JOIN kends.`toponymio` TOPO ON MON.`MONA_TOPO_KWD` = TOPO.`TOPO_KWD`
  LEFT JOIN kends.`nomos` NOMSYP ON TOPO.`NOMO_KWD` = NOMSYP.`NOMO_KWD`
WHERE STR.STRK_PROS_KWD in ($P!{STRK_PROS_KWD})]]>
	</queryString>
	<field name="STRK_PROS_KWD" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="STRK_PROS_KWD"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="ken_stratevmenos"/>
	</field>
	<field name="MONA_LEK" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="MONA_LEK"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="monada"/>
	</field>
	<field name="SYPO" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="SYPO"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="monada"/>
	</field>
	<field name="NOMOS SYPO" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="NOMOS SYPO"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="nomos"/>
	</field>
	<field name="TOPOS SYPO" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="TOPOS SYPO"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="toponymio"/>
	</field>
	<group name="STRK_PROS_KWD">
		<groupExpression><![CDATA[$F{STRK_PROS_KWD}]]></groupExpression>
	</group>
	<group name="MONA_LEK">
		<groupExpression><![CDATA[$F{MONA_LEK}]]></groupExpression>
	</group>

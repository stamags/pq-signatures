	<subDataset name="SXOLES" uuid="ff67c2dd-9d01-4978-94f9-d4dd086c471c">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT XWR.XWRA_LEK,SXOL.SXOL_LEK
FROM ken_stratevmenos STR
  inner join ken_morfwsh MOR ON STR.STRK_PROS_KWD = MOR.STRK_PROS_KWD
  left join xwra XWR ON  MOR.XWRA_KWD=XWR.XWRA_KWD
  left join sxolh SXOL ON MOR.SXOL_KWD=SXOL.SXOL_KWD
WHERE STR.STRK_PROS_KWD = $P{STRK_PROS_KWD}]]>
		</queryString>
		<field name="XWRA_LEK" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="XWRA_LEK"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="xwra"/>
		</field>
		<field name="SXOL_LEK" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="SXOL_LEK"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="sxolh"/>
		</field>
		<group name="XWRA_LEK">
			<groupExpression><![CDATA[$F{XWRA_LEK}]]></groupExpression>
		</group>
		<group name="SXOL_LEK">
			<groupExpression><![CDATA[$F{SXOL_LEK}]]></groupExpression>
		</group>
	</subDataset>
	<subDataset name="GLWSSES" uuid="a9de9231-95db-4488-9294-d3d50c1b1594">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT GLWS.GLWS_LEK, EPID.XENH_GLWS_EPID_LEK
FROM ken_stratevmenos STR
         LEFT JOIN ken_xenes_glwsses LANG ON STR.STRK_PROS_KWD = LANG.STRK_PROS_KWD
         LEFT JOIN glwssa GLWS ON LANG.GLWS_KWD = GLWS.GLWS_KWD
         LEFT JOIN xenh_glwssa_epidosh EPID on LANG.XENH_GLWS_EPID_KWD = EPID.XENH_GLWS_EPID_KWD
WHERE STR.STRK_PROS_KWD = $P{STRK_PROS_KWD}]]>
		</queryString>
		<field name="GLWS_LEK" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="GLWS_LEK"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="glwssa"/>
		</field>
		<field name="XENH_GLWS_EPID_LEK" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="XENH_GLWS_EPID_LEK"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="xenh_glwssa_epidosh"/>
		</field>
		<group name="GLWS_LEK">
			<groupExpression><![CDATA[$F{GLWS_LEK}]]></groupExpression>
		</group>
		<group name="XENH_GLWS_EPID_LEK">
			<groupExpression><![CDATA[$F{XENH_GLWS_EPID_LEK}]]></groupExpression>
		</group>
	</subDataset>
	<subDataset name="EPITHIMIES" uuid="af88f930-dfa5-400d-9c81-5b5fb44a0f25">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT topo.EPIT_TOPO_AA, e.EPAR_LEK
  FROM ken_epithymies_topothethshs topo
INNER JOIN eparxia e on topo.EPAR_KWD = e.EPAR_KWD
WHERE topo.STRK_PROS_KWD = $P{STRK_PROS_KWD}
ORDER BY topo.EPIT_TOPO_AA ASC]]>
		</queryString>
		<field name="EPIT_TOPO_AA" class="java.lang.Integer">
			<property name="com.jaspersoft.studio.field.label" value="EPIT_TOPO_AA"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="ken_epithymies_topothethshs"/>
		</field>
		<field name="EPAR_LEK" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="EPAR_LEK"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="eparxia"/>
		</field>
		<group name="EPIT_TOPO_AA">
			<groupExpression><![CDATA[$F{EPIT_TOPO_AA}]]></groupExpression>
		</group>
		<group name="EPAR_LEK">
			<groupExpression><![CDATA[$F{EPAR_LEK}]]></groupExpression>
		</group>
	</subDataset>
	<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT STR.STRK_PROS_KWD, B.BATH_SYN, YPHR.ENDEIXI_YEA, O.OS_SYN, YPHR.YPHR_ESSO, XWR.XWRA_LEK,SXOL.SXOL_LEK,STR.STRA_EPWNYMO, STR.STRA_ONOMA, STR.STRA_PATRWNYMO, STR.STRA_MHTRONYMO, STR.STRA_GRAF_KWD, STR.STRA_ASM, STR.STRA_KLASH, M.MONA_LEK, EID.EIDI_LEK, DATE_FORMAT(ATOM.ATOM_HMNIA_GENNHSHS, '%d/%m/%Y'), KAT.KATA_EFED_LEK, THRI.THRI_LEK, E.EPAG_LEK, ATOM.AFM, ATOM.ATOM_AR_AST_TAYT, DOY.DOY_LEK, STAT.OIKO_KATA_LEK, OIK.OIKO_TEKNA, SWM.SWMA_YPSOS, SWM.SWMA_BAROS, SWM.SWMA_NO_STOLIS, SWM.SWMA_NO_ARVI, SWM.SWMA_PER_STHTHOYS, SWM.SWMA_PER_MESHS, SWM.SWMA_PER_LAIMOY, SWM.SWMA_MHKOS_KAVALOY, SWM.SWMA_MHKOS_PELMATOS, SWM.SWMA_PERIM_PELMATOS, SWM.SWMA_PERIM_MHROY, SWM.SWMA_PERIM_KEFALHS, SWM.SWMA_PERIF_LEKANHS, EP.EPIP_MORF_LEK, TOPO.TOPO_LEK, NOM.NOMO_LEK, ATOM.ATOM_DIEYTHYNSH, ATOM.ATOM_TAXKWD, ATOM.ATOM_THLEFWNO, ASTY.ASTY_TMHM_LEK, TOPGEN.TOPO_LEK AS "POLH GENNHSHS", NOMGEN.NOMO_LEK AS "NOMOS GENNHSHS", AIM.AIMA_SYN, SYG.SYG_ONOMA, SYG.SYG_ODOS, SYG.SYG_ARITHMOS, SYG.SYG_TK, SYG.SYG_THLEFONO, TOPSYG.TOPO_LEK AS "POLH SYGGENH", NOMSYG.NOMO_LEK AS "NOMOS SYGGENH", ASTYSYG.ASTY_TMHM_LEK AS "AT SYGGENH", EPAG.EPAG_PROYPHRESIA, DKT_MOR.DEIK_MORF_LEK AS "DEIKTHS MORFWSHS",ORAS.ORAS_LEK AS "ORASH", IAT.IATR_AXRWMATOPSIA_DKT AS "AXRWMATOPSIA", AKO.AKOH_SYN AS "AKOH", EXT.MONADA_TOPOTH, EXT.YPOMONADA_TOPOTH, DIPLPOL.DIPL_POLI_LEK AS "DIPLWMA", YPHR.YPHR_PROYPHR_HMERES AS "PROYPHRESIA",IPO.EPEN_EKST,IPO.XIT_STOL_EXOD,IPO.PANT_STOL_EXOD,IPO.DIKOXO,YPHR.ANIPOTAKTOS,YPHR.POINES_60_DKT,IPO.POUK_XEIM_STOL,IPO.XIT_STOL_ERG,IPO.PANT_STOL_ERG, IKAN.IKAN_EFED_SYN AS "IKANOTHTA", EPIT.EPIT_ELDYK_DKT AS "EPITH ELDYK", EPIT.EPIT_OHE_DKT AS "EPITH OHE", EPIT.EPIT_YPAX_DKT AS "EPITH YPAX",  DATE_FORMAT(YPHR.HMER_EGGRAFIS_SIPO, '%d/%m/%Y'), YPHR.MINES_ANAVOLIS, IPOMON.IPOMONADA
FROM ken_stratevmenos STR
  left join ken_atomika ATOM ON STR.STRK_PROS_KWD = ATOM.STRK_PROS_KWD
  left join ken_yphresiaka YPHR ON STR.STRK_PROS_KWD = YPHR.STRK_PROS_KWD
  left join ken_oikogeneiaka OIK ON STR.STRK_PROS_KWD = OIK.STRK_PROS_KWD
   left join ipologismos_swm IPO ON STR.STRK_PROS_KWD = IPO.STRK_PROS_KWD
  left join ken_diplwmata_politika DIPLALL ON STR.STRK_PROS_KWD = DIPLALL.STRK_PROS_KWD
  left join diplwma_politiko DIPLPOL ON DIPLALL.DIPL_POLI_KDW = DIPLPOL.DIPL_POLI_KWD
  inner join ken_morfwsh MOR ON STR.STRK_PROS_KWD = MOR.STRK_PROS_KWD
  left join deikths_morfwshs DKT_MOR on MOR.DEIK_MORF_KWD = DKT_MOR.DEIK_MORF_KWD
  left join ken_iatrika IAT ON STR.STRK_PROS_KWD = IAT.STRK_PROS_KWD
  left join aima AIM ON IAT.AIMA_KWD = AIM.AIMA_KWD
  left join orash ORAS ON IAT.ORAS_KWD = ORAS.ORAS_KWD
  left join akoh AKO ON IAT.AKOH_KWD = AKO.AKOH_KWD
  left join astynomiko_tmhma ASTY ON ATOM.ASTY_TMHM_DIAM_KWD = ASTY.ASTY_TMHM_KWD
  left join toponymio TOPO ON ATOM.TOPO_DIAM_KWD = TOPO.TOPO_KWD
  left join toponymio TOPGEN ON ATOM.TOPO_GENH_KWD = TOPGEN.TOPO_KWD
  left join ken_sygeneis SYG ON STR.STRK_PROS_KWD = SYG.STRK_PROS_KWD
  left join toponymio TOPSYG ON SYG.SYG_POLI = TOPSYG.TOPO_KWD
  left join nomos NOM ON TOPO.NOMO_KWD = NOM.NOMO_KWD
  left join nomos NOMGEN ON TOPGEN.NOMO_KWD = NOMGEN.NOMO_KWD
  left join nomos NOMSYG ON TOPSYG.NOMO_KWD = NOMSYG.NOMO_KWD
  left join astynomiko_tmhma ASTYSYG ON SYG.SYG_ASTY_TMHM = ASTYSYG.ASTY_TMHM_KWD
  left join epipedo_morfwshs EP ON MOR.EPIP_MORF_KWD = EP.EPIP_MORF_KWD
  left join ken_swmatometrika SWM ON STR.STRK_PROS_KWD = SWM.STRK_PROS_KWD
  left join oikogeneiakh_katastash STAT ON OIK.OIKO_KATA_KWD = STAT.OIKO_KATA_KWD
  left join ken_epaggelmata EPAG ON STR.STRK_PROS_KWD = EPAG.STRK_PROS_KWD
  left join epaggelma E ON EPAG.EPAG_KWD = E.EPAG_KWD
  left join ken_yphresiaka YP ON STR.STRK_PROS_KWD = YP.STRK_PROS_KWD
  left join bathmos B ON YP.BATH_KWD = B.BATH_KWD
  left join os O ON YP.OS_KWD = O.OS_KWD
  left join eidikothta EID ON YP.YPHR_EIDI_KWD = EID.EIDI_KWD
  left join katastash_efedrou KAT ON STR.KATA_EFED_KWD = KAT.KATA_EFED_KWD
  left join thriskia THRI ON ATOM.THRI_KWD = THRI.THRI_KWD
  left join doy DOY ON ATOM.DOY_KWD = DOY.DOY_KWD
  left join monada M ON YP.YPHR_META_MONA_KWD = M.MONA_KWD
   left join xwra XWR ON  MOR.XWRA_KWD=XWR.XWRA_KWD
  left join sxolh SXOL ON MOR.SXOL_KWD=SXOL.SXOL_KWD
  left join ikanothta_efedrou IKAN ON STR.IKAN_EFED_KWD = IKAN.IKAN_EFED_KWD
  left join ken_epithymia EPIT ON STR.STRK_PROS_KWD = EPIT.STRK_PROS_KWD
  left join ken_extra_stoixeia EXT ON STR.STRK_PROS_KWD = EXT.STRK_PROS_KWD
  left join ipomonada IPOMON ON EXT.YPOMONADA_TOPOTH = IPOMON.STR_KW_IPOM
WHERE STR.STRK_PROS_KWD = $P{STRK_PROS_KWD}]]>
	</queryString>

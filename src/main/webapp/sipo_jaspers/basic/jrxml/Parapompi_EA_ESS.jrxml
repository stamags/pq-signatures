				</textElement>
				<textFieldExpression><![CDATA["Ο υπογεγραμμένος Ιατρός " +  $F{BATHMOS IATROU}  +" "+ $F{ONOM/MO IATROU} + "  υπεύθυνος για την υγειονομική υπηρεσία........................................................................................... εξέτασα τον  (βαθμός) " + $F{BATH_SYN} + " (" + $F{OS_SYN} + ") " +" (ονοματ.)   " + $F{STRA_EPWNYMO} + " " + $F{STRA_ONOMA} +"  (ον. πατρός)  " + $F{STRA_PATRWNYMO} + "  με ΑΣΜ: " + ($F{STRK_PROS_KWD} == null ? "-" : $F{STRK_PROS_KWD}) + " και θρήσκευμα " + ($F{THRI_SYN} == null ? "-" : $F{THRI_SYN}) + "  που είναι εγγεγραμμένος    στα     μητρώα     αρρένων     του Δήμου  " +( $F{TOPO_LEK}== null ? "-" :$F{TOPO_LEK} ) + " ,Επαρχίας " + ($F{EPAR_LEK}  == null ? "-" :$F{EPAR_LEK}) +   "  ,Νομού " + ($F{NOMO_LEK} == null ? "-" : $F{NOMO_LEK} )+ "  ,και βρήκα αυτόν όπως παρακάτω: "]]></textFieldExpression>
			</textField>

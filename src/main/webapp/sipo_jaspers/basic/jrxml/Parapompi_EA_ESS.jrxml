	</subDataset>
	<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT STR.STRK_PROS_KWD,
       B.BATH_SYN,
       O.OS_SYN,
       STR.STRA_EPWNYMO,
       STR.STRA_ONOMA,
       STR.STRA_PATRWNYMO,
       M.MONA_LEK,
       TOPO.TOPO_LEK,
       NOM.NOMO_LEK,
       EPAR.EPAR_LEK,
       IKAN.IKAN_EFED_SYN                       AS "IKANOTHTA",
       DATE_FORMAT(YPHR.HMER_EGGRAFIS_SIPO, '%d/%m/%Y'),
       DATE_FORMAT(ATOM.ATOM_HMNIA_GENNHSHS, '%d/%m/%Y'),
       TOPOSYPO.TOPO_LEK                        AS "TOPOS SYPO",
       SI.IKAN_GNWMATEYSH,
       THRI.THRI_SYN,
       SI.IKAN_ISXYO_SI,
       PD.PD_ARTHRO,
       DATE_FORMAT(SI.IKAN_HMNIA, '%d/%m/%Y'),
       SI.IKAN_AR_GNWMAT,
       EA.EPIT_APALL_LEK,
       IPOG.ID                                  AS "ID",
       CONCAT(IPOG.EPWNYMO, " ", IPOG.ONOMA)    AS "ONOM/MO IATROU",
       CONCAT(BA.BATH_LEK, "(", OS.OS_SYN, ")") AS "BATHMOS IATROU"
FROM ken_stratevmenos STR
         left join ken_atomika ATOM ON STR.STRK_PROS_KWD = ATOM.STRK_PROS_KWD
         left join ken_yphresiaka YPHR ON STR.STRK_PROS_KWD = YPHR.STRK_PROS_KWD
         left join ken_iatrika IAT ON STR.STRK_PROS_KWD = IAT.STRK_PROS_KWD
         left join toponymio TOPO ON ATOM.TOPO_MHTRWA_KWD = TOPO.TOPO_KWD
         left join nomos NOM ON TOPO.NOMO_KWD = NOM.NOMO_KWD
         LEFT JOIN eparxia EPAR ON TOPO.EPAR_KWD = EPAR.EPAR_KWD
         left join bathmos B ON YPHR.BATH_KWD = B.BATH_KWD
         left join os O ON YPHR.OS_KWD = O.OS_KWD
         left join eidikothta EID ON YPHR.YPHR_EIDI_KWD = EID.EIDI_KWD
         left join katastash_efedrou KAT ON STR.KATA_EFED_KWD = KAT.KATA_EFED_KWD
         left join thriskia THRI ON ATOM.THRI_KWD = THRI.THRI_KWD
         left join doy DOY ON ATOM.DOY_KWD = DOY.DOY_KWD
         left join monada M ON YPHR.YPHR_META_MONA_KWD = M.MONA_KWD
         left join toponymio TOPOSYPO ON M.MONA_TOPO_KWD = TOPOSYPO.TOPO_KWD
         left join ken_ikanothtes SI ON STR.STRK_PROS_KWD = SI.STRK_PROS_KWD
         left join pd_133_02 PD ON SI.IKAN_PD_PARAG = PD.PD_PARAG_KWD
         left join ikanothta_efedrou IKAN ON IKAN.IKAN_EFED_KWD = SI.IKAN_EFED_KWD
         left join EPITROPH_APALLAGWN EA ON SI.IKAN_EPITROPH_APALL = EA.EPIT_APALL_KWD,
     ipografes IPOG
         LEFT JOIN bathmos BA on IPOG.BATH_KWD = BA.BATH_KWD
         LEFT JOIN os OS on IPOG.OS_KWD = OS.OS_KWD
WHERE  IPOG.ID = 9 and STR.STRK_PROS_KWD = $P{STRK_PROS_KWD}]]>
	</queryString>

       DATE_FORMAT(ATOM.ATOM_HMNIA_GENNHSHS, '%d/%m/%Y'),
       TOPGEN.TOPO_LEK,
       TOPDHM.TOPO_LEK
FROM ken_stratevmenos ST
         LEFT JOIN ken_yphresiaka YP ON ST.STRK_PROS_KWD = YP.STRK_PROS_KWD
         LEFT JOIN os OS ON ST.OS_KWD = OS.OS_KWD
         LEFT JOIN bathmos BATH ON YP.BATH_KWD = BATH.BATH_KWD
         LEFT JOIN ken_atomika ATOM ON ST.STRK_PROS_KWD = ATOM.STRK_PROS_KWD
         LEFT JOIN toponymio TOPGEN ON ATOM.TOPO_GENH_KWD = TOPGEN.TOPO_KWD
         LEFT JOIN toponymio TOPDHM ON ATOM.TOPO_DIAM_KWD = TOPDHM.TOPO_KWD
WHERE ST.STRK_PROS_KWD IN  ($P!{STRK_PROS_KWD})]]>

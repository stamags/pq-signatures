		<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT ST.STRK_PROS_KWD,
       BATH.BATH_OLOGRAFOS_EN,
       ST.STRA_SURNAME,
       ST.STRA_NAME,
       ST.STRA_FATH_NAME,
       DATE_FORMAT(ATOM.ATOM_HMNIA_GENNHSHS, '%d/%m/%Y'),
       ATOM.XRWM_MAL,
       ATOM.XRWM_MAT,
       SWM.SWMA_YPSOS,
       AIM.OMADA_SYNT_EN,
       AIM.RESHUS_EN
FROM ken_stratevmenos ST
         LEFT JOIN ken_yphresiaka YP ON ST.STRK_PROS_KWD = YP.STRK_PROS_KWD
         LEFT JOIN bathmos BATH ON YP.BATH_KWD = BATH.BATH_KWD
         LEFT JOIN ken_atomika ATOM ON ST.STRK_PROS_KWD = ATOM.STRK_PROS_KWD
         LEFT JOIN ken_swmatometrika SWM ON ST.STRK_PROS_KWD = SWM.STRK_PROS_KWD
         LEFT JOIN ken_iatrika IAT ON ST.STRK_PROS_KWD = IAT.STRK_PROS_KWD
         LEFT JOIN aima AIM ON IAT.AIMA_KWD = AIM.AIMA_KWD
WHERE ST.STRK_PROS_KWD IN  ($P!{STRK_PROS_KWD})]]>
		</queryString>

					<font fontName="Arial" size="12" isBold="false" isUnderline="false" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[Ο ΠΡΟΕΔΡΟΣ]]></text>
			</staticText>

			<textField>
				<reportElement positionType="Float" x="10" y="179" width="521" height="129" uuid="6cbf077a-2fba-406a-82a7-8362c9a2e20e"/>
				<textElement textAlignment="Justified" verticalAlignment="Top" markup="html">
					<font fontName="Arial" size="12" pdfFontName="arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<textFieldExpression><![CDATA["αφού εξέτασε τη σωματική ικανότητα του " + $F{BATH_SYN} + " (" + $F{OS_SYN} + ") " + $F{STRA_EPWNYMO} + " " + $F{STRA_ONOMA} + " του " + $F{STRA_PATRWNYMO} + " γραμμένου στα μητρώα αρρένων του Δήμου ή Κοινότητας " + $F{POLH GENNHSHS}  + " του Νομού " +$F{NOMOS GENNHSHS} + " με ημερομηνία γεννήσεως " + ($F{DATE_FORMAT(ATOM.ATOM_HMNIA_GENNHSHS, '%d/%m/%Y')} == null ? " - " : $F{DATE_FORMAT(ATOM.ATOM_HMNIA_GENNHSHS, '%d/%m/%Y')})  + ", (ΣΑ : " + $F{STRK_PROS_KWD} + "), και έλαβε υπ' όψη του τη γνωμοδότηση του υγειονομικού  μέλους, κρίνεται Ικανός " + $F{IKANOTHTA} + " πάσχων από " + ($F{IKAN_GNWMATEYSH} == null ? "-" : $F{IKAN_GNWMATEYSH} ) +  ", σύμφωνα με την παράγραφο " + ($F{PD_ARTHRO} == null ? " - " : $F{PD_ARTHRO}) + " του ΠΔ 11/2014."   + "<br/>" + "Αριθμός Απόφασης : " +( ($F{IKAN_AR_GNWMAT} == null ? "-" : $F{IKAN_AR_GNWMAT}) + " / " + ($F{EPIT_APALL_LEK} == null ? "-" : $F{EPIT_APALL_LEK}))]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement positionType="Float" x="0" y="308" width="210" height="15" uuid="c7c051ec-ac8c-4f39-a656-28c3fa66af77"/>

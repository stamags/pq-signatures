					<font fontName="Arial" size="12" isBold="false" isUnderline="false" pdfFontName="C:\Windows\Fonts\arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<text><![CDATA[Ο ΠΡΟΕΔΡΟΣ]]></text>

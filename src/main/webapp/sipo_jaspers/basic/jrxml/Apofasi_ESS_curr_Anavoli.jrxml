					<font fontName="Arial" size="12" pdfFontName="C:\Windows\Fonts\arial.ttf" pdfEncoding="Identity-H"/>
				</textElement>
				<textFieldExpression><![CDATA["αφού εξέτασε τη σωματική ικανότητα του "+$F{BATH_SYN} + " (" + $F{OS_SYN} + ") " + $F{STRA_EPWNYMO} + " " + $F{STRA_ONOMA} + " του " + $F{STRA_PATRWNYMO} + " γραμμένου στα μητρώα αρρένων του Δήμου ή Κοινότητας "  + $F{POLH GENNHSHS} + " του Νομού " + $F{NOMOS GENNHSHS} + " με ημερομηνία γεννήσεως " + ($F{DATE_FORMAT(ATOM.ATOM_HMNIA_GENNHSHS, '%d/%m/%Y')} == null ? " - " : $F{DATE_FORMAT(ATOM.ATOM_HMNIA_GENNHSHS, '%d/%m/%Y')}) +  ", (ΣΑ : " + $F{STRK_PROS_KWD} + "), και έλαβε υπ' όψη του τη γνωμοδότηση του υγειονομικού μέλους, έλαβε "+  ($F{MINES_ANAVOLIS}  == null ? "-" : $F{MINES_ANAVOLIS}) + " μηνη αναβολή υγείας πάσχων από : " + ($F{IKAN_GNWMATEYSH} == null ? "-" : $F{IKAN_GNWMATEYSH}) + " , σύμφωνα με την παράγραφο  " + ($F{PD_ARTHRO} == null ? " - " : $F{PD_ARTHRO}) + " του ΠΔ 11/2014. " + "<br/>" + " Αριθμός Απόφασης : " + ($F{IKAN_AR_GNWMAT} == null ? "-" : $F{IKAN_AR_GNWMAT}) + "/" + ($F{EPIT_APALL_LEK} == null ? "-" : $F{EPIT_APALL_LEK})]]></textFieldExpression>
			</textField>
			<staticText>

	<subDataset name="KEN_SIPO" uuid="f960e17e-b179-414e-bba8-ca4adcce5332">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="KENDS LOCALHOST"/>
		<queryString language="SQL">
			<![CDATA[SELECT STR.`STRK_PROS_KWD`, B.BATH_SYN, O.OS_SYN,    
 EPI.EPIT_STOIX_INTERNET_DKT,
 YPHR.YPHR_ESSO, 
 STR.STRA_EPWNYMO, 
 STR.STRA_ONOMA, 
 STR.STRA_PATRWNYMO,
  STR.STRA_MHTRONYMO,
   STR.STRA_GRAF_KWD, 
   STR.STRA_ASM, 
  STR.STRA_KLASH,
   M.MONA_LEK, 
   EID.EIDI_LEK,
   DATE_FORMAT(ATOM.ATOM_HMNIA_GENNHSHS, '%d/%m/%Y'),
    KAT.KATA_EFED_LEK, THRI.THRI_LEK, 
    E.EPAG_LEK, 
    ATOM.AFM, 
    ATOM.ATOM_AR_AST_TAYT,
     DOY.DOY_LEK, 
    STAT.OIKO_KATA_LEK,
     OIK.OIKO_TEKNA, 
    SWM.SWMA_YPSOS, 
    SWM.SWMA_BAROS,
     SWM.SWMA_NO_STOLIS,
      SWM.SWMA_NO_ARVI,
       EP.EPIP_MORF_LEK, 
      TOPO.TOPO_LEK, 
      NOM.NOMO_LEK, 
      ATOM.ATOM_DIEYTHYNSH,
       ATOM.ATOM_TAXKWD, 
       ATOM.ATOM_THLEFWNO, 
       ASTY.ASTY_TMHM_LEK, GLWS.GLWS_LEK, 
       EPID.XENH_GLWS_EPID_LEK, 
       TOPGEN.TOPO_LEK AS "POLH GENNHSHS",
        NOMGEN.NOMO_LEK AS "NOMOS GENNHSHS",
        TOPMHTRWA.TOPO_LEK  AS "POLH MHTRWA",
  NOMMHTRWA.NOMO_LEK       AS "NOMOS MHTRWA",
         AIM.AIMA_SYN, 
         SYG.SYG_ONOMA, SYG.SYG_ODOS, SYG.SYG_ARITHMOS, 
         SYG.SYG_TK, SYG.SYG_THLEFONO, 
         TOPSYG.TOPO_LEK AS "POLH SYGGENH", 
         NOMSYG.NOMO_LEK AS "NOMOS SYGGENH", 
         ASTYSYG.ASTY_TMHM_LEK AS "AT SYGGENH", 
         EPAG.EPAG_PROYPHRESIA
FROM `ken_stratevmenos` STR
INNER JOIN `ken_atomika` ATOM ON STR.STRK_PROS_KWD = ATOM.STRK_PROS_KWD
INNER JOIN `ken_yphresiaka` YPHR ON STR.STRK_PROS_KWD = YPHR.STRK_PROS_KWD
INNER JOIN `ken_oikogeneiaka` OIK ON STR.STRK_PROS_KWD = OIK.STRK_PROS_KWD
INNER JOIN `ken_morfwsh` MOR ON STR.STRK_PROS_KWD = MOR.STRK_PROS_KWD
INNER JOIN `ken_epithymia` EPI ON STR.STRK_PROS_KWD = EPI.STRK_PROS_KWD
INNER JOIN `ken_xenes_glwsses` LANG ON STR.STRK_PROS_KWD = LANG.STRK_PROS_KWD
INNER JOIN `glwssa` GLWS ON LANG.GLWS_KWD = GLWS.GLWS_KWD 
INNER JOIN `xenh_glwssa_epidosh` EPID ON LANG.EPIP_GLWS_KWD = EPID.XENH_GLWS_EPID_KWD
INNER JOIN `ken_iatrika` IAT ON STR.STRK_PROS_KWD = IAT.STRK_PROS_KWD
INNER JOIN `aima` AIM ON IAT.AIMA_KWD = AIM.AIMA_KWD
INNER JOIN `astynomiko_tmhma` ASTY ON ATOM.ASTY_TMHM_DIAM_KWD = ASTY.ASTY_TMHM_KWD
INNER JOIN `toponymio` TOPO ON ATOM.TOPO_DIAM_KWD = TOPO.TOPO_KWD
INNER JOIN `toponymio` TOPGEN ON ATOM.TOPO_GENH_KWD = TOPGEN.TOPO_KWD
INNER JOIN `toponymio` TOPMHTRWA ON ATOM.TOPO_MHTRWA_KWD = TOPMHTRWA.TOPO_KWD
INNER JOIN `ken_sygeneis` SYG ON STR.STRK_PROS_KWD = SYG.STRK_PROS_KWD
INNER JOIN `toponymio` TOPSYG ON SYG.SYG_POLI = TOPSYG.TOPO_KWD
INNER JOIN `nomos` NOM ON TOPO.NOMO_KWD = NOM.NOMO_KWD
INNER JOIN `nomos` NOMGEN ON TOPGEN.NOMO_KWD = NOMGEN.NOMO_KWD
INNER JOIN `nomos` NOMSYG ON TOPSYG.NOMO_KWD = NOMSYG.NOMO_KWD
INNER JOIN `nomos` NOMMHTRWA ON TOPMHTRWA.NOMO_KWD = NOMMHTRWA.NOMO_KWD
INNER JOIN `astynomiko_tmhma` ASTYSYG ON SYG.SYG_ASTY_TMHM = ASTYSYG.ASTY_TMHM_KWD
INNER JOIN `epipedo_morfwshs` EP ON MOR.EPIP_MORF_KWD = EP.EPIP_MORF_KWD
INNER JOIN `ken_swmatometrika` SWM ON STR.STRK_PROS_KWD = SWM.STRK_PROS_KWD
INNER JOIN `oikogeneiakh_katastash` STAT ON OIK.OIKO_KATA_KWD = STAT.OIKO_KATA_KWD
INNER JOIN `ken_epaggelmata` EPAG ON STR.STRK_PROS_KWD = EPAG.STRK_PROS_KWD
INNER JOIN `epaggelma` E ON EPAG.EPAG_KWD = E.EPAG_KWD
INNER JOIN `ken_yphresiaka` YP ON STR.STRK_PROS_KWD = YP.STRK_PROS_KWD
INNER JOIN `bathmos` B ON YP.BATH_KWD = B.BATH_KWD
INNER JOIN `os` O ON YP.OS_KWD = O.OS_KWD
INNER JOIN `eidikothta` EID ON YP.YPHR_EIDI_KWD = EID.EIDI_KWD
INNER JOIN `katastash_efedrou` KAT ON STR.KATA_EFED_KWD = KAT.KATA_EFED_KWD
INNER JOIN `thriskia` THRI ON ATOM.THRI_KWD = THRI.THRI_KWD
INNER JOIN `doy` DOY ON ATOM.DOY_KWD = DOY.DOY_KWD
INNER JOIN `monada` M ON YP.YPHR_META_MONA_KWD = M.MONA_KWD]]>
		</queryString>

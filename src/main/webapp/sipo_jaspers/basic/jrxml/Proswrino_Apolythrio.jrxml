	<subDataset name="STG" uuid="d67c2f1f-6428-4556-ae40-3c8be73a42c5">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT GRAFEIO.STRA_GRAF_LEK FROM
  stg GRAFEIO, ken_stratevmenos KS
WHERE GRAFEIO.STRA_GRAF_KWD IN (SELECT LEFT(KS.STRK_PROS_KWD, 3) FROM ken_stratevmenos) AND ks.STRK_PROS_KWD = $P{STRK_PROS_KWD}]]>
		</queryString>
		<field name="STRA_GRAF_LEK" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="STRA_GRAF_LEK"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="stg"/>
		</field>
		<group name="STRA_GRAF_LEK">
			<groupExpression><![CDATA[$F{STRA_GRAF_LEK}]]></groupExpression>
		</group>
	</subDataset>
	<subDataset name="DKTHS" uuid="90929d61-64be-40e6-8584-1260b785edff">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="kends"/>
		<queryString language="SQL">
			<![CDATA[SELECT IPOG.ID AS "ID" , CONCAT(IPOG.EPWNYMO, " ", IPOG.ONOMA) AS "ONOM/MO IPOGRAFONTA", CONCAT(B.BATH_LEK, "(", O.OS_SYN, ")" ) AS "BATHMOS IPOGRAFONTA"
FROM ipografes IPOG
LEFT JOIN bathmos B on IPOG.BATH_KWD = B.BATH_KWD
LEFT JOIN os O on IPOG.OS_KWD = O.OS_KWD
WHERE IPOG.ID = 4]]>
		</queryString>
		<field name="ONOM/MO IPOGRAFONTA" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="ONOM/MO IPOGRAFONTA"/>
		</field>
		<field name="BATHMOS IPOGRAFONTA" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="BATHMOS IPOGRAFONTA"/>
		</field>
		<group name="ONOM/MO IPOGRAFONTA">
			<groupExpression><![CDATA[$F{ONOM/MO IPOGRAFONTA}]]></groupExpression>
		</group>
		<group name="BATHMOS IPOGRAFONTA">
			<groupExpression><![CDATA[$F{BATHMOS IPOGRAFONTA}]]></groupExpression>
		</group>
	</subDataset>
	<subDataset name="SXIMATISMOS" uuid="352df88e-dc2f-488d-b924-3092685fc3d9">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="KENDS"/>
		<queryString language="SQL">
			<![CDATA[SELECT ONOMA_SXHM FROM diaxeirsi_ipografwn]]>
		</queryString>
		<field name="ONOMA_SXHM" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="ONOMA_SXHM"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="sximatismos"/>
		</field>
	</subDataset>
	<parameter name="STRK_PROS_KWD" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  STR.STRK_PROS_KWD,
  STR.STRA_EPWNYMO,
  STR.STRA_ONOMA,
  STR.STRA_PATRWNYMO,
  STR.STRA_KLASH,
  M.MONA_LEK,
  DATE_FORMAT(ATOM.ATOM_HMNIA_GENNHSHS, '%d/%m/%Y'),
  TOPO.TOPO_LEK,
  NOM.NOMO_LEK,
  ATOM.ATOM_DIEYTHYNSH,
  ATOM.ATOM_TAXKWD,
  ASTY.ASTY_TMHM_LEK,
  TOPGEN.TOPO_LEK AS "POLH GENNHSHS",
  NOMGEN.NOMO_LEK AS "NOMOS GENNHSHS",
  TOPMHTRWA.TOPO_LEK AS "POLH MHTRWA",
  NOMMHTRWA.NOMO_LEK AS "NOMOS MHTRWA",
  TOPOSYPO.TOPO_LEK AS "TOPOS SYPO",
  YPHR.YPHR_LEKTIKO AS "ANAVOLH"
FROM ken_stratevmenos STR
  left join ken_atomika ATOM ON STR.STRK_PROS_KWD = ATOM.STRK_PROS_KWD
  left join ken_yphresiaka YPHR ON STR.STRK_PROS_KWD = YPHR.STRK_PROS_KWD
  left join astynomiko_tmhma ASTY ON ATOM.ASTY_TMHM_DIAM_KWD = ASTY.ASTY_TMHM_KWD
  left join toponymio TOPO ON ATOM.TOPO_DIAM_KWD = TOPO.TOPO_KWD
  left join toponymio TOPGEN ON ATOM.TOPO_GENH_KWD = TOPGEN.TOPO_KWD
  left join toponymio TOPMHTRWA ON ATOM.TOPO_MHTRWA_KWD = TOPMHTRWA.TOPO_KWD
  left join nomos NOM ON TOPO.NOMO_KWD = NOM.NOMO_KWD
  left join nomos NOMGEN ON TOPGEN.NOMO_KWD = NOMGEN.NOMO_KWD
   left join nomos NOMMHTRWA ON TOPMHTRWA.NOMO_KWD = NOMMHTRWA.NOMO_KWD
  left join ken_yphresiaka YP ON STR.STRK_PROS_KWD = YP.STRK_PROS_KWD
  left join monada M ON YP.YPHR_META_MONA_KWD = M.MONA_KWD
  left join toponymio TOPOSYPO ON M.MONA_TOPO_KWD = TOPOSYPO.TOPO_KWD
WHERE STR.STRK_PROS_KWD = $P{STRK_PROS_KWD}]]>
	</queryString>
